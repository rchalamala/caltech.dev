{
  "name": "caltech-dev",
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@formkit/auto-animate": "^0.9.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "flatpickr": "^4.6.13",
    "framer-motion": "^12.38.0",
    "fzf": "^0.5.2",
    "moment": "^2.30.1",
    "react": "^19.2.5",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.5",
    "react-flatpickr": "^4.0.11",
    "react-select": "^5.10.2"
  },
  "scripts": {
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:ts && bun run lint:css",
    "lint:ts": "oxlint src vite.config.ts --type-aware --react-plugin --jsx-a11y-plugin --import-plugin -D correctness -D suspicious -D perf --deny-warnings -A react-in-jsx-scope -A no-unassigned-import -A jsx-no-constructed-context-values",
    "lint:css": "stylelint \"src/**/*.css\"",
    "build": "bun run typecheck && vite build",
    "check": "bun run typecheck && bun run lint && vite build",
    "preview": "vite preview",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/react-flatpickr": "^3.8.11",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "postcss": "^8.5.14",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-svgr": "^5.2.0",
    "wrangler": "^4.87.0"
  }
}
